# === Django 核心配置 ===
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_ALLOWED_HOSTS=your-domain.com,api.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com

# === 数据库配置 ===
POSTGRES_DB=xiaoshuo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# === Redis 缓存配置 ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# === JWT 认证配置 ===
JWT_ACCESS_TOKEN_MINUTES=120
JWT_REFRESH_TOKEN_DAYS=7

# === AI 内容相关 ===
OPENAI_COMPAT_API_KEYS=demo-writer-token

# === Agnes 智能体系统 (必需) ===
# 从 https://console.anthropic.com 获取 API 密钥
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Agnes 定时任务配置（可选）
AGNES_INTERVAL_MINUTES=30
AGNES_AUTO_PUBLISH=true

# === 前端 API 配置 ===
VITE_API_BASE_URL=https://your-domain.com/api/v1